# Environment template for dronomy-loc. Copy to .env and fill in real values.
# .env is gitignored (see .gitignore) — never commit real keys or credentials.
# Every value below is optional: the keyless reference providers (esri / ign /
# pnoa) and the offline test suite need none of these.

# ── Google Earth Engine reference provider (reference/gee.py) ─────────────
# Cloud project that owns the EE access. Required for the `gee` provider unless
# set in config (reference.gee.project).
EE_PROJECT=
# Headless / service-account auth (CI, servers). Leave both blank to use an
# interactive `earthengine authenticate` session instead.
EE_SERVICE_ACCOUNT=
# Path to the service-account JSON key file (e.g. /run/secrets/ee-key.json).
EE_SERVICE_ACCOUNT_KEY=

# ── Optional map/imagery API key ──────────────────────────────────────────
# Reserved for keyed satellite/basemap sources. Not needed by the current
# keyless providers; set only if a provider that requires it is added.
GOOGLE_MAPS_API_KEY=

# ── exiftool (data/telemetry.py) ──────────────────────────────────────────
# Full path to the exiftool binary used to decode the embedded GPS track.
# Leave blank to auto-discover it on PATH / common Windows locations.
EXIFTOOL=

# ── MatchAnything backend (matching/matchanything.py, Docker-only) ────────
# Path to the imcui config that defines the matchanything_* zoo entries. Set
# inside docker/Dockerfile.matchanything; leave blank in the main env (the
# loader falls back to the packaged imcui config).
IMCUI_CONFIG=
